{
    "buildCommand": "cd .. && cd landing && npm install && npm run build",
    "outputDirectory": "landing/dist",
    "installCommand": "cd .. && cd landing && npm install",
    "framework": "vite",
    "github": {
        "silent": false,
        "autoJobCancelation": false
    },
    "deploymentProtection": {
        "preview": "none",
        "production": "none"
    },
    "rewrites": [
        {
            "source": "/api/scribe/:path*",
            "destination": "https://hanna-line-bot-production.up.railway.app/api/scribe/:path*"
        },
        {
            "source": "/scribe/app/:path*",
            "destination": "/scribe/app/index.html"
        }
    ]
}
