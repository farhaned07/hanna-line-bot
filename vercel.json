{
    "buildCommand": "cd scribe && npm install && npm run build",
    "outputDirectory": "scribe/dist",
    "installCommand": "cd scribe && npm install",
    "framework": "vite",
    "github": {
        "silent": false,
        "autoJobCancelation": true
    },
    "deploymentProtection": {
        "preview": "none",
        "production": "none"
    },
    "rewrites": [
        {
            "source": "/scribe/(.*)",
            "destination": "/scribe/index.html"
        }
    ]
}
