# ═══════════════════════════════════════════════════════════
# HANNA SCRIBE — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ─── Core Backend ───
DATABASE_URL=postgresql://user:password@localhost:5432/hanna
BASE_URL=https://your-app.railway.app

# ─── LINE Integration (Care Intelligence only) ───
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_NOTIFY_TOKEN=your_line_notify_token

# ─── AI Services ───
GROQ_API_KEY=your_groq_api_key
# Groq SDK uses Llama 3.3 70B for clinical note generation

# Deepgram API (for audio transcription)
# Required for Scribe voice-to-text
# Get free key: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── Voice Services (Care Intelligence only) ───
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Supabase (Care Intelligence only) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ─── Stripe Billing (Scribe) ───
# Required for Scribe subscription payments
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx_pro
STRIPE_CLINIC_PRICE_ID=price_xxx_clinic

# ─── Authentication ───
JWT_SECRET=your_jwt_secret_min_32_chars_random
NURSE_DASHBOARD_TOKEN=your_secure_nurse_token
ADMIN_SECRET=your_admin_secret

# ═══════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT VARIABLES (VITE_ prefix required)
# ═══════════════════════════════════════════════════════════

# ─── Scribe PWA (scribe/) ───
# Backend API URL for Scribe frontend
VITE_API_URL=https://your-app.railway.app

# Scribe authentication token (for demo/guest access)
VITE_SCRIBE_TOKEN=demo

# ─── Nurse Dashboard (client/) ───
VITE_NURSE_TOKEN=your_secure_nurse_token
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── LINE Voice Interface (hanna-web/) ───
LIFF_ID=2008593893-Bj5k3djg
