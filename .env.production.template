# ═══════════════════════════════════════════════════════════
# HANNA PRODUCTION ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ─── Node Environment ──────────────────────────────────────
NODE_ENV=production

# ─── Server Configuration ──────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ─── Database (Supabase PostgreSQL) ────────────────────────
# Get from: https://app.supabase.com/project/_/settings/database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres

# ─── JWT Secret (Generate a strong random string) ──────────
# Use: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# ─── LINE Bot Configuration ────────────────────────────────
# Get from: https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LIFF_ID=your-liff-id

# ─── AI Services ───────────────────────────────────────────
# Groq (for note generation): https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-api-key

# OpenAI (for Whisper transcription): https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Stripe Billing (Production) ───────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Product/Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_ID_PRO=price_your-pro-plan-price-id
STRIPE_PRICE_ID_CLINIC=price_your-clinic-plan-price-id

# ─── Email (Resend) ────────────────────────────────────────
# Get from: https://resend.com/apikeys
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Hanna <noreply@hanna.care>

# ─── LiveKit (Voice Calls) ─────────────────────────────────
# Get from: https://cloud.livekit.io/
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ─── URLs ──────────────────────────────────────────────────
PRODUCTION_URL=https://hanna.care
SCRIBE_URL=https://hanna.care/scribe/app
DASHBOARD_URL=https://hanna.care/dashboard

# ─── Sentry (Error Monitoring) ─────────────────────────────
# Optional but recommended: https://sentry.io/
SENTRY_DSN=https://your-sentry-dsn

# ─── Session Timeout (milliseconds) ────────────────────────
SESSION_TIMEOUT=1800000
SESSION_WARNING=1500000

# ─── File Upload Limits ────────────────────────────────────
MAX_FILE_SIZE=52428800

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=/var/log/hanna/app.log

# ─── Backup Configuration ──────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
